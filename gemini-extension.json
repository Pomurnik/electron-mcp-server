{
  "name": "electron-mcp-server",
  "version": "2.0.1",
  "description": "MCP server for Electron application automation and management.",
  "mcpServers": {
    "electron": {
      "command": "node",
      "args": ["${extensionPath}${/}dist${/}index.js"],
      "cwd": "${extensionPath}",
      "env": {
        "SECURITY_LEVEL": "balanced"
      }
    }
  },
  "contextFileName": "GEMINI.md"
}
